# -----------------------------
# Auto normalize line endings
# -----------------------------
* text=auto

# -----------------------------
# Python files (backend)
# -----------------------------
*.py text eol=lf
*.pyi text eol=lf

# -----------------------------
# Django / HTML templates
# -----------------------------
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.txt text eol=lf

# -----------------------------
# JavaScript / React frontend
# -----------------------------
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# -----------------------------
# Markdown / Docs
# -----------------------------
*.md text eol=lf

# -----------------------------
# Optional: prevent conversion of binaries
# -----------------------------
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary


